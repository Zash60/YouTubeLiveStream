<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 1. Permissões de Rede e Streaming -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 2. Permissões de Áudio (Microfone/Interno) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 3. Permissões de Serviço em Segundo Plano (CRÍTICO) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Necessário para capturar a tela no Android 10+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- 4. Permissão de Notificação (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 5. Permissão para o Widget Flutuante -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 6. Permissões para Selecionar Imagem de "Já Volto" -->
    <!-- Para Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Para Android 12 e inferiores -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YouTubeLiveStream"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        
        <!-- usesCleartextTraffic="true" é essencial para conexões RTMP não criptografadas -->

        <!-- Atividade Principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Atividade de Configurações -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings"
            android:parentActivityName=".MainActivity" />

        <!-- Serviço de Streaming (Core) -->
        <!-- foregroundServiceType é OBRIGATÓRIO aqui -->
        <service
            android:name=".StreamingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Serviço do Controle Flutuante -->
        <service
            android:name=".FloatingControlService"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>
