<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Image Selection Section (NEW) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🖼️ Imagem de 'Já Volto'"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2d2d44"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtImageStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma imagem selecionada (Usará Tela Preta)"
                    android:textColor="#aaaaaa"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="160dp"
                    android:layout_height="90dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    android:background="#000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnSelectImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escolher da Galeria"
                        android:backgroundTint="#2196F3"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnRemoveImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remover"
                        android:backgroundTint="#F44336"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Video Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬 Configurações de Vídeo"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Resolution -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resolução"
            android:textColor="#cccccc"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- FPS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS (Quadros por segundo)"
            android:textColor="#cccccc"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerFps"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Video Bitrate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bitrate de Vídeo (kbps)"
            android:textColor="#cccccc"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerVideoBitrate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Audio Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊 Configurações de Áudio"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Audio Bitrate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bitrate de Áudio (kbps)"
            android:textColor="#cccccc"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerAudioBitrate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Sample Rate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Taxa de Amostragem (Hz)"
            android:textColor="#cccccc"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerSampleRate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

        <!-- Configuração de Rede -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 Estabilidade de Rede"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/spinner_background"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bitrate Adaptativo"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reduz a qualidade se a internet oscilar."
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchAdaptiveBitrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#FF0000"
                android:trackTint="#aaaaaa" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="💾 Salvar Configurações"
            android:textSize="16sp"
            android:backgroundTint="#00c853" />

    </LinearLayout>

</ScrollView>
