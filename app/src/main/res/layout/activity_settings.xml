<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Imagem de Pausa -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🖼️ Imagem de 'Já Volto'"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2d2d44"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtImageStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma imagem selecionada"
                    android:textColor="#aaaaaa"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="160dp"
                    android:layout_height="90dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    android:background="#000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">
                    <Button
                        android:id="@+id/btnSelectImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escolher da Galeria"
                        android:backgroundTint="#2196F3"
                        android:layout_marginEnd="8dp"/>
                    <Button
                        android:id="@+id/btnRemoveImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remover"
                        android:backgroundTint="#F44336"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ÁUDIO MIXER (NOVO) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎚️ Mixer de Áudio"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volume do Microfone"
            android:textColor="#cccccc" />
        <SeekBar
            android:id="@+id/seekMicVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volume do Jogo (Interno)"
            android:textColor="#cccccc" />
        <SeekBar
            android:id="@+id/seekInternalVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_marginBottom="24dp" />

        <!-- CODEC DE VÍDEO (NOVO) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬 Codec de Vídeo"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Spinner
            android:id="@+id/spinnerCodec"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="24dp" />

        <!-- Resolução e FPS (Existentes) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resolução"
            android:textColor="#cccccc" />
        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS"
            android:textColor="#cccccc" />
        <Spinner
            android:id="@+id/spinnerFps"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bitrate Vídeo"
            android:textColor="#cccccc" />
        <Spinner
            android:id="@+id/spinnerVideoBitrate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bitrate Áudio"
            android:textColor="#cccccc" />
        <Spinner
            android:id="@+id/spinnerAudioBitrate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Taxa Amostragem"
            android:textColor="#cccccc" />
        <Spinner
            android:id="@+id/spinnerSampleRate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_background"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="💾 Salvar Configurações"
            android:textSize="16sp"
            android:backgroundTint="#00c853" />

    </LinearLayout>
</ScrollView>
